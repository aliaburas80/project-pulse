# Google Cloud OAuth credentials. Redirect URI must be:
# https://YOUR-RENDER-URL/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Generate with: openssl rand -base64 32
# Required in production. It encrypts the signed-in Google session cookie.
SESSION_PASSWORD=replace-with-a-long-random-string-at-least-32-characters

# The public URL of the deployed app (no trailing slash)
APP_URL=http://localhost:3000
PORT=3000
